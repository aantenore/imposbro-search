{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imposbro.local/contracts/enterprise-e2e-evidence-v1.1.schema.json",
  "title": "IMPOSBRO enterprise E2E evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "finished_at",
    "status",
    "provenance",
    "scenarios"
  ],
  "properties": {
    "schema_version": { "const": "1.1" },
    "run_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "status": {
      "enum": ["running", "passed", "failed", "incomplete"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "required_scenarios": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]{3,128}$"
          }
        }
      },
      "required": [
        "git_commit",
        "git_dirty",
        "dependency_mode",
        "runtime",
        "runner",
        "python",
        "platform",
        "evidence_scope",
        "production_certification",
        "required_scenarios",
        "capabilities"
      ]
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "started_at",
          "finished_at",
          "duration_ms",
          "assertions"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]{3,128}$" },
          "status": { "enum": ["passed", "failed", "not_run"] },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "assertions": { "type": "object" },
          "reason": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": { "enum": ["failed", "not_run"] }
              }
            },
            "then": { "required": ["reason"] }
          }
        ]
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captured_at", "truncated", "log_tail"],
      "properties": {
        "captured_at": { "type": "string", "format": "date-time" },
        "truncated": { "type": "boolean" },
        "log_tail": { "type": "string", "maxLength": 16000 }
      }
    }
  }
}
