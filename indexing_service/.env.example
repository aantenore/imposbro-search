# Enterprise default: accept only the versioned event envelope.
INDEXING_ALLOW_LEGACY_EVENTS=false

# Production/enterprise: PostgreSQL transaction fences every event target.
INDEXING_CHECKPOINT_BACKEND=postgres
CONTROL_PLANE_DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/imposbro
INDEXING_CHECKPOINT_LOCK_TIMEOUT_MS=5000

# Typesense checkpoints are development-only and have no cross-process fence.
INDEXING_CHECKPOINT_COLLECTION=_imposbro_indexing_checkpoints
INDEXING_ALLOW_TYPESENSE_CHECKPOINTS=false

# Volatile in-memory checkpoints are also development/test only.
INDEXING_ALLOW_VOLATILE_CHECKPOINTS=false

# Existing worker settings.
INDEXING_MAX_PROCESSING_ATTEMPTS=3
KAFKA_METADATA_MAX_AGE_MS=5000
KAFKA_MAX_POLL_INTERVAL_MS=300000
KAFKA_MAX_POLL_RECORDS=1
INDEXING_METRICS_ENABLED=true
INDEXING_METRICS_PORT=9108
INDEXING_HEALTH_PORT=9109

# OpenTelemetry trace export. Enterprise requires OTLP/HTTP over TLS and
# non-development build/revision values.
OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=none
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com:4318
OTEL_EXPORTER_OTLP_TIMEOUT=5000
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_BSP_EXPORT_TIMEOUT=5000
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1
OTEL_SERVICE_NAME=imposbro-indexing-service
OTEL_SERVICE_VERSION=4.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_BUILD_ID=development
OTEL_SERVICE_REVISION=development
# Supply OTEL_EXPORTER_OTLP_HEADERS only through a secret manager when needed.

# Kafka transport. Enterprise uses SASL_SSL with credentials supplied by Secret.
KAFKA_BROKER_URL=kafka:29092
KAFKA_TOPIC_PREFIX=imposbro_search_sharded
INDEXING_KAFKA_CONSUMER_GROUP_ID=imposbro_federated_indexing_group
INDEXING_KAFKA_CONSUMER_CLIENT_ID=imposbro-indexing-consumer
INDEXING_KAFKA_DLQ_CLIENT_ID=imposbro-indexing-dlq
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CAFILE=
KAFKA_SSL_CERTFILE=
KAFKA_SSL_KEYFILE=
KAFKA_SSL_CHECK_HOSTNAME=true
