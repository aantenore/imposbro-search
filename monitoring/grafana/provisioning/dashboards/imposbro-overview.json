{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {"id": 1, "title": "Total Documents Ingested", "type": "stat", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum(documents_ingested_total)", "legendFormat": "Total Documents"}]},
    {"id": 2, "title": "Documents by Collection (1h)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum by (collection) (increase(documents_ingested_total[1h]))", "legendFormat": "{{collection}}"}]},
    {"id": 3, "title": "Query API: Request Rate (5m)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum by (handler, method) (rate(http_requests_total{job=\"imposbro_services\"}[5m]))", "legendFormat": "{{method}} {{handler}}"}]},
    {"id": 4, "title": "Query API: P95 Latency", "type": "timeseries", "datasource": {"type": "prometheus"}, "unit": "s", "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"imposbro_services\"}[5m])) by (le))", "legendFormat": "P95"}]},
    {"id": 5, "title": "Error Rate (5xx)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum(rate(http_requests_total{job=\"imposbro_services\",status=\"5xx\"}[5m]))", "legendFormat": "5xx"}]},
    {"id": 6, "title": "Indexed Documents by Cluster (1h)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum by (target_cluster) (increase(indexing_documents_indexed_total[1h]))", "legendFormat": "{{target_cluster}}"}]},
    {"id": 7, "title": "Indexing Retries (1h)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum by (error) (increase(indexing_processing_retries_total[1h]))", "legendFormat": "{{error}}"}]},
    {"id": 8, "title": "Indexing DLQ Messages (1h)", "type": "stat", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum(increase(indexing_dlq_messages_total[1h]))", "legendFormat": "DLQ"}]},
    {"id": 9, "title": "Rate Limit Blocks (1h)", "type": "timeseries", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum by (action, collection) (increase(query_api_rate_limit_checks_total{result=\"blocked\"}[1h]))", "legendFormat": "{{action}} {{collection}}"}]},
    {"id": 10, "title": "Rate Limit Backend Errors (1h)", "type": "stat", "datasource": {"type": "prometheus"}, "targets": [{"expr": "sum(increase(query_api_rate_limit_backend_errors_total[1h]))", "legendFormat": "Backend errors"}]}
  ],
  "title": "IMPOSBRO Search Overview"
}
