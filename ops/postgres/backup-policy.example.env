# Non-secret policy example for scripts/ops/backup-control-plane-postgres.sh.
# Store credentials and age identities in the platform secret manager, never here.

BACKUP_SOURCE_ID=production-eu
BACKUP_RETENTION_CLASS=daily-35d
BACKUP_EXPECTED_ALEMBIC_REVISION=0003_audit_delivery_deletion
AGE_RECIPIENT=age1replace-with-public-recipient

# Libpq connection fields. PGPASSWORD is intentionally omitted; prefer a
# secret-injected PGPASSFILE or workload identity supported by the platform.
PGHOST=postgres.internal.example
PGPORT=5432
PGDATABASE=imposbro
PGUSER=imposbro_backup
PGSSLMODE=verify-full
