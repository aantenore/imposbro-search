# Required service endpoints for E2E_DEPENDENCY_MODE=external.
E2E_POSTGRES_URL=postgresql+psycopg://user:password@postgres.example:5432/imposbro?sslmode=verify-full
E2E_REDIS_URL='rediss://redis.example:6379/0?ssl_cert_reqs=required&ssl_ca_certs=/absolute/path/to/enterprise-ca.pem'
E2E_QUERY_A_URL=https://query-a.example
E2E_QUERY_B_URL=https://query-b.example
E2E_WORKER_HEALTH_URL=https://indexing-worker.example
E2E_TYPESENSE_A_URL=https://typesense-a.example:8108
E2E_TYPESENSE_B_URL=https://typesense-b.example:8108

# Supply real values only via the process environment or a local ignored file.
# E2E_TYPESENSE_API_KEY must be the disposable cluster administration key used
# only to create/revoke two short-lived rotation probes.
E2E_TYPESENSE_API_KEY=
E2E_TYPESENSE_A_API_KEY=
E2E_TYPESENSE_B_API_KEY=
E2E_ADMIN_API_KEY=
E2E_DATA_API_KEY=

# ENT-06 mutates this approved mounted-secret path atomically. The deployed
# clusters must expose file: and env: refs matching these locators.
E2E_TYPESENSE_SECRET_FILE=/absolute/path/to/writable/typesense-api-key
E2E_EXPECTED_TYPESENSE_FILE_REF=file:typesense-api-key
E2E_EXPECTED_TYPESENSE_ENV_REF=env:E2E_TYPESENSE_ENV_KEY

# Short-lived operator-issued OIDC test tokens. Use a disposable test tenant;
# never export production user tokens into this harness.
E2E_TENANT_A_TOKEN=
E2E_TENANT_B_TOKEN=
E2E_TENANT_NO_CLAIM_TOKEN=

# TLS verification probe. CA path is local to the runner host.
E2E_TLS_TYPESENSE_URL=https://typesense-a.example:8108
E2E_TLS_CA_FILE=/absolute/path/to/enterprise-ca.pem

# Read-only TLS capture endpoint used to query spans by W3C trace id.
E2E_OTLP_CAPTURE_URL=https://otel-capture.example:4318
E2E_OTLP_CA_FILE=/absolute/path/to/enterprise-ca.pem

# Explicit executable hooks; they receive no arguments. The start hook is also
# called by the cleanup trap if a later assertion fails.
E2E_STOP_REDIS_HOOK=/absolute/path/to/stop-disposable-redis
E2E_START_REDIS_HOOK=/absolute/path/to/start-disposable-redis
E2E_RESTART_QUERY_B_HOOK=/absolute/path/to/restart-disposable-query-b
# Receives one destination filename and writes bounded Query API + worker logs.
E2E_CAPTURE_APPLICATION_LOGS_HOOK=/absolute/path/to/capture-application-logs
