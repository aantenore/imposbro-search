{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imposbro.dev/contracts/indexing-event-v2.schema.json",
  "title": "IMPOSBRO indexing event v2",
  "description": "One logical, ordered document mutation. Kafka records must be keyed by tenant_id, collection, and document_id joined with U+001F.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "event_id",
    "identity",
    "document_version",
    "sequence",
    "operation",
    "routing_revision",
    "rollout_id",
    "target_clusters",
    "occurred_at",
    "trace"
  ],
  "properties": {
    "envelope_version": { "const": 2 },
    "event_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{8,128}$"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id", "collection", "document_id"],
      "properties": {
        "tenant_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "collection": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,128}$"
        },
        "document_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]{1,256}$"
        }
      }
    },
    "document_version": { "type": "integer", "minimum": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "operation": { "enum": ["upsert", "delete", "tombstone"] },
    "routing_revision": { "type": "integer", "minimum": 1 },
    "rollout_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[A-Za-z0-9_.:-]{8,128}$" }
      ]
    },
    "target_clusters": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_-]{1,128}$"
      }
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": { "type": "string", "maxLength": 1024 },
        "correlation_id": { "type": "string", "maxLength": 1024 },
        "traceparent": { "type": "string", "maxLength": 1024 },
        "tracestate": { "type": "string", "maxLength": 1024 }
      }
    },
    "document": { "type": "object", "minProperties": 1 },
    "delete_filter": { "type": "string", "minLength": 1, "maxLength": 4096 }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "upsert" } } },
      "then": {
        "required": ["document"],
        "not": { "required": ["delete_filter"] }
      },
      "else": { "not": { "required": ["document"] } }
    }
  ]
}
