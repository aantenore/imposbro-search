# IMPOSBRO SEARCH - Environment Variables
# Copy to .env and adjust for your environment.

# --- Kafka & Redis Configuration ---
KAFKA_BROKER_URL=kafka:29092
KAFKA_TOPIC_PREFIX=imposbro_search_sharded
# Refresh Kafka metadata frequently so the indexing service sees newly created collection topics.
KAFKA_METADATA_MAX_AGE_MS=5000
# Bounded retries before a failed indexing message is quarantined to <topic_prefix>_dlq.
INDEXING_MAX_PROCESSING_ATTEMPTS=3
# Expose indexing worker Prometheus metrics on this port.
INDEXING_METRICS_ENABLED=true
INDEXING_METRICS_PORT=9108
REDIS_URL=redis://redis:6379

# --- Internal State Cluster Configuration ---
# Typesense HA cluster used to store federation config and routing rules
INTERNAL_STATE_NODES=typesense-state-1,typesense-state-2,typesense-state-3
INTERNAL_STATE_API_KEY=a-very-secret-internal-key

# --- Default Federated Data Cluster Configuration ---
# First cluster used for user data (required)
DEFAULT_DATA_CLUSTER_NODES=typesense-data-1,typesense-data-2,typesense-data-3
DEFAULT_DATA_CLUSTER_API_KEY=a-secret-federated-key

# --- Second Federated Data Cluster (optional) ---
# Leave empty to use a single data cluster
DEFAULT_DATA2_CLUSTER_NODES=typesense-data2-1,typesense-data2-2,typesense-data2-3
DEFAULT_DATA2_CLUSTER_API_KEY=another-secret-key

# --- Admin UI & Service Discovery ---
# URL used by Admin UI and Indexing Service to reach the Query API
INTERNAL_QUERY_API_URL=http://query_api:8000

# --- Local Docker Compose networking ---
# Typesense stores Raft peers as resolved IPs. Keep these stable when reusing
# Docker volumes across compose down/up. Override if the subnet conflicts locally.
COMPOSE_SUBNET=172.28.0.0/16
TYPESENSE_STATE_1_IP=172.28.0.11
TYPESENSE_STATE_2_IP=172.28.0.12
TYPESENSE_STATE_3_IP=172.28.0.13
TYPESENSE_DATA_1_IP=172.28.0.21
TYPESENSE_DATA_2_IP=172.28.0.22
TYPESENSE_DATA_3_IP=172.28.0.23
TYPESENSE_DATA2_1_IP=172.28.0.31
TYPESENSE_DATA2_2_IP=172.28.0.32
TYPESENSE_DATA2_3_IP=172.28.0.33

# --- CORS (optional) ---
# Comma-separated origins to allow (e.g. http://localhost:3001). Empty = same-origin only.
# CORS_ORIGINS=http://localhost:3001

# --- Admin API key (optional) ---
# If set, all /admin/* requests require X-API-Key or Authorization: Bearer.
# For local-only Docker Compose development, ALLOW_UNAUTHENTICATED_ADMIN=true
# lets you use the Admin UI without a key. Keep it false in shared/prod environments.
ALLOW_UNAUTHENTICATED_ADMIN=true
# ADMIN_API_KEY=your-secret-admin-key
# Optional server-side key used by the Admin UI proxy; defaults to ADMIN_API_KEY when omitted.
# INTERNAL_QUERY_API_ADMIN_API_KEY=your-secret-admin-key

# Optional scoped API keys for least-privilege clients. Supported scopes:
# admin, search, ingest, data (search+ingest), and *.
# SCOPED_API_KEYS=[{"name":"search-client","key":"secret","scopes":["search"]}]

# --- Data-plane API key (optional) ---
# If set, /ingest/* and /search/* require X-API-Key or Authorization: Bearer.
# For local-only Docker Compose development, ALLOW_UNAUTHENTICATED_DATA=true
# lets smoke tests and manual API calls run without a key. Keep it false in shared/prod environments.
ALLOW_UNAUTHENTICATED_DATA=true
# DATA_API_KEY=your-secret-data-key
# Optional server-side key used by the Admin UI proxy; defaults to DATA_API_KEY when omitted.
# INTERNAL_QUERY_API_DATA_API_KEY=your-secret-data-key

# --- Admin audit log ---
# Records successful control-plane mutations to the internal state cluster.
AUDIT_LOG_ENABLED=true
AUDIT_LOG_MAX_RESULTS=100
