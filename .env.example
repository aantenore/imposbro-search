# IMPOSBRO SEARCH - Environment Variables
# Copy to .env and adjust for your environment.

# --- Kafka & Redis Configuration ---
KAFKA_BROKER_URL=kafka:29092
KAFKA_TOPIC_PREFIX=imposbro_search_sharded
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL_CAFILE=/var/run/secrets/imposbro/kafka/ca.crt
# KAFKA_SSL_CERTFILE=/var/run/secrets/imposbro/kafka/tls.crt
# KAFKA_SSL_KEYFILE=/var/run/secrets/imposbro/kafka/tls.key
KAFKA_SSL_CHECK_HOSTNAME=true
KAFKA_CLIENT_ID=imposbro-query-api
INDEXING_KAFKA_CONSUMER_GROUP_ID=imposbro_federated_indexing_group
INDEXING_KAFKA_DLQ_GROUP_ID=imposbro_indexing_dlq_resolver
KAFKA_OPERATION_TIMEOUT_MS=5000
ROUTING_CUTOVER_MAX_KAFKA_LAG=0
# Refresh Kafka metadata frequently so the indexing service sees newly created collection topics.
KAFKA_METADATA_MAX_AGE_MS=5000
# Bounded retries before a failed indexing message is quarantined to <topic_prefix>_dlq.
INDEXING_MAX_PROCESSING_ATTEMPTS=3
# v2 is the default and required in enterprise; enable legacy only during a
# bounded development migration.
INDEXING_ALLOW_LEGACY_EVENTS=false
INDEXING_IDEMPOTENCY_BACKEND=typesense
INDEXING_CHECKPOINT_COLLECTION=_imposbro_indexing_checkpoints
INDEXING_ALLOW_VOLATILE_CHECKPOINTS=false
# Expose indexing worker Prometheus metrics on this port.
INDEXING_METRICS_ENABLED=true
INDEXING_METRICS_PORT=9108
# Optional benchmark artifact paths used by scripts/benchmark-k8s.py.
# BENCHMARK_OUTPUT_JSON=artifacts/benchmark-release.json
# BENCHMARK_OUTPUT_MARKDOWN=artifacts/benchmark-release.md
# Optional benchmark metadata recorded in JSON/Markdown release evidence.
# BENCHMARK_ENVIRONMENT=staging-eu
# BENCHMARK_RELEASE=v1.0.0
# BENCHMARK_CLUSTER_SHAPE=query=3,indexing=5,typesense=2x3,kafka=3
# BENCHMARK_HELM_VALUES_REF=release-values/staging-eu.yaml
# BENCHMARK_IMAGE_SET=query-api@sha256:...,indexing@sha256:...,admin-ui@sha256:...
# BENCHMARK_EVIDENCE_NOTES=baseline before tenant rollout
REDIS_URL=redis://redis:6379
# Optional Redis config-sync source id. Leave empty to use hostname:pid per process.
# CONFIG_SYNC_SOURCE_ID=query-api-1

# --- Deployment and control-plane profile ---
# development preserves the local Typesense state backend. enterprise fails
# startup unless PostgreSQL CAS, OIDC, tenant policy, rate-limit and TLS controls
# are configured. See docs/ENTERPRISE_DELIVERY_CONTRACT.md.
DEPLOYMENT_PROFILE=development
LOG_FORMAT=text
LOG_LEVEL=INFO
# OpenTelemetry is disabled for local development. Enterprise requires
# OTLP/HTTP over TLS plus immutable build/revision metadata.
OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=none
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://otel-collector.example.com:4318/v1/traces
OTEL_EXPORTER_OTLP_TIMEOUT=5000
OTEL_BSP_SCHEDULE_DELAY=5000
OTEL_BSP_EXPORT_TIMEOUT=5000
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1
OTEL_SERVICE_NAME=imposbro-query-api
OTEL_SERVICE_VERSION=4.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_BUILD_ID=development
OTEL_SERVICE_REVISION=development
# Supply OTEL_EXPORTER_OTLP_HEADERS only through a secret manager when needed.
CONTROL_PLANE_STORE_BACKEND=typesense
INDEXING_EVENT_STORE_BACKEND=disabled
# Production form requires server identity verification:
# postgresql+psycopg://user:password@host:5432/database?sslmode=verify-full&sslrootcert=/path/ca.crt
# CONTROL_PLANE_DATABASE_URL=
CONTROL_PLANE_RECONCILE_SECONDS=5
CONTROL_PLANE_OUTBOX_POLL_SECONDS=1
CONTROL_PLANE_OUTBOX_BATCH_SIZE=100
CONTROL_PLANE_OUTBOX_MAX_PENDING=1000
CONTROL_PLANE_MIGRATION_LOCK_TIMEOUT_SECONDS=60
INDEXING_OUTBOX_POLL_SECONDS=1
INDEXING_OUTBOX_BATCH_SIZE=100
# Freeze only admin mutations during a legacy Typesense -> PostgreSQL cutover.
CONTROL_PLANE_ADMIN_MUTATIONS_FROZEN=false

# --- Internal State Cluster Configuration ---
# Typesense HA cluster used to store federation config and routing rules
INTERNAL_STATE_NODES=typesense-state-1,typesense-state-2,typesense-state-3
INTERNAL_STATE_API_KEY=a-very-secret-internal-key
# Production/enterprise: clear the inline key and resolve an external value,
# for example INTERNAL_STATE_API_KEY_REF=env:IMPOSBRO_SECRET_INTERNAL_STATE_API_KEY
INTERNAL_STATE_API_KEY_REF=
INTERNAL_STATE_PROTOCOL=http

# --- Default Federated Data Cluster Configuration ---
# First cluster used for user data (required)
DEFAULT_DATA_CLUSTER_NODES=typesense-data-1,typesense-data-2,typesense-data-3
DEFAULT_DATA_CLUSTER_API_KEY=a-secret-federated-key
# Production/enterprise: use env:NAME or file:relative/path under the root below.
DEFAULT_DATA_CLUSTER_API_KEY_REF=
DEFAULT_DATA_CLUSTER_PROTOCOL=http

# --- Second Federated Data Cluster (optional) ---
# Leave empty to use a single data cluster
DEFAULT_DATA2_CLUSTER_NODES=typesense-data2-1,typesense-data2-2,typesense-data2-3
DEFAULT_DATA2_CLUSTER_API_KEY=another-secret-key
DEFAULT_DATA2_CLUSTER_API_KEY_REF=
DEFAULT_DATA2_CLUSTER_PROTOCOL=http
TYPESENSE_SECRET_FILE_ROOT=/run/secrets/imposbro

# --- Admin UI & Service Discovery ---
# URL used by Admin UI and Indexing Service to reach the Query API
INTERNAL_QUERY_API_URL=http://query_api:8000

# --- Local Docker Compose networking ---
# Bind published Docker Compose ports to localhost by default. Override only for
# trusted lab networks, never for unauthenticated shared environments.
HOST_BIND_IP=127.0.0.1
# Typesense stores Raft peers as resolved IPs. Keep these stable when reusing
# Docker volumes across compose down/up. Override if the subnet conflicts locally.
COMPOSE_SUBNET=172.28.0.0/16
TYPESENSE_STATE_1_IP=172.28.0.11
TYPESENSE_STATE_2_IP=172.28.0.12
TYPESENSE_STATE_3_IP=172.28.0.13
TYPESENSE_DATA_1_IP=172.28.0.21
TYPESENSE_DATA_2_IP=172.28.0.22
TYPESENSE_DATA_3_IP=172.28.0.23
TYPESENSE_DATA2_1_IP=172.28.0.31
TYPESENSE_DATA2_2_IP=172.28.0.32
TYPESENSE_DATA2_3_IP=172.28.0.33

# --- CORS (optional) ---
# Comma-separated origins to allow (e.g. http://localhost:3001). Empty = same-origin only.
# CORS_ORIGINS=http://localhost:3001

# --- Request correlation ---
# Header echoed by Query API responses and propagated into Kafka data-plane messages.
REQUEST_ID_HEADER=X-Request-ID
# Versioned ingest/delete events use these configurable headers. Enterprise
# clients must supply document version and idempotency key; sequence defaults to
# document version. Batch clients can instead use event_metadata keyed by doc id.
IDEMPOTENCY_KEY_HEADER=Idempotency-Key
DOCUMENT_VERSION_HEADER=X-Document-Version
EVENT_SEQUENCE_HEADER=X-Event-Sequence
# serving keeps initialized Query API instances routable while dependencies are
# degraded. Use strict to require Redis, Kafka, and every data node to be healthy.
READINESS_POLICY=serving

# --- Admin API key (optional) ---
# If set, all /admin/* requests require X-API-Key or Authorization: Bearer.
# For local-only Docker Compose development, ALLOW_UNAUTHENTICATED_ADMIN=true
# lets you use the Admin UI without a key. Keep it false in shared/prod environments.
ALLOW_UNAUTHENTICATED_ADMIN=true
# ADMIN_API_KEY=your-secret-admin-key
# Optional service-to-service admin key used by the Admin UI proxy and indexing worker;
# defaults to ADMIN_API_KEY when omitted. When it differs from ADMIN_API_KEY, include
# it in SCOPED_API_KEYS with admin:internal, admin, or * scope so Query API accepts it.
# INTERNAL_QUERY_API_ADMIN_API_KEY=your-secret-admin-key
# Production-only: when the Admin UI proxy injects server-side API keys, require
# an authenticated ingress/gateway to set this exact trusted identity header/value.
# ADMIN_UI_PUBLIC_ORIGIN=https://admin.example.com
ADMIN_UI_SECURITY_PROFILE=development
ADMIN_UI_SERVER_CREDENTIAL_MODE=disabled
ADMIN_UI_ALLOW_LEGACY_TRUSTED_HEADER=false
ADMIN_UI_ENTERPRISE_MODE=false
# ADMIN_UI_PROXY_TRUSTED_HEADER=x-authenticated-user
# ADMIN_UI_PROXY_TRUSTED_VALUE=operator

# --- Admin UI OIDC login/session (optional) ---
# Lets browser operators sign in through an OIDC Authorization Code + PKCE flow.
# The Admin UI stores a sealed HttpOnly session cookie and proxies the resulting
# access token as Authorization: Bearer to the Query API. The callback requires
# an id_token and validates nonce, audience, issuer when configured, and token
# timestamps before creating the session. Enable Query API OIDC/JWT bearer-token
# validation above with matching issuer/audience/scopes.
ADMIN_UI_OIDC_ENABLED=false
# ADMIN_UI_SESSION_SECRET=replace-with-at-least-32-random-characters
# ADMIN_UI_OIDC_CLIENT_ID=imposbro-admin-ui
# ADMIN_UI_OIDC_CLIENT_SECRET=optional-confidential-client-secret
# ADMIN_UI_OIDC_ISSUER=https://idp.example.com/
# The issuer remains mandatory when explicit endpoints replace discovery:
# ADMIN_UI_OIDC_AUTHORIZATION_ENDPOINT=https://idp.example.com/oauth2/authorize
# ADMIN_UI_OIDC_TOKEN_ENDPOINT=https://idp.example.com/oauth2/token
# ADMIN_UI_OIDC_JWKS_URL=https://idp.example.com/.well-known/jwks.json
# ADMIN_UI_OIDC_ALLOWED_ENDPOINT_ORIGINS=https://login.example.com
ADMIN_UI_OIDC_ALLOW_INSECURE_LOCALHOST=false
ADMIN_UI_OIDC_FETCH_TIMEOUT_MS=5000
ADMIN_UI_OIDC_SCOPES=openid profile email imposbro:admin imposbro:data
# ADMIN_UI_OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback
ADMIN_UI_SESSION_TTL_SECONDS=3600

# Optional scoped API keys for least-privilege clients. Supported scopes:
# admin, admin:read, admin:write, admin:backup, admin:restore, admin:internal,
# search (search/read), ingest (document writes/deletes), data (search/read+ingest/delete), and *.
# Collection scopes also support safe glob patterns: search:products_*, ingest:orders_*, data:tenant_a_*.
# SCOPED_API_KEYS=[{"name":"catalog-reader","key":"secret","scopes":["search:products_*"]}]
# Tenant-bound machine principals add claims and an ISO-8601 expiry, for example:
# SCOPED_API_KEYS=[{"name":"tenant-a-writer","key":"secret","scopes":["ingest:orders_*"],"claims":{"tenant_id":["tenant-a"]},"expires_at":"2027-01-01T00:00:00Z"}]

# --- OIDC/JWT bearer tokens (optional) ---
# Enterprise gateways can send Authorization: Bearer <JWT>. API keys are still
# accepted and checked first. Tokens must match issuer, audience, signature, and
# configured claim mapping. Default required token claim values are namespaced:
# imposbro:admin, imposbro:admin:read/write/backup/restore/internal,
# imposbro:search, imposbro:ingest, imposbro:data, imposbro:*.
OIDC_ENABLED=false
# OIDC_ISSUER=https://idp.example.com/
# OIDC_AUDIENCE=imposbro-api
# OIDC_JWKS_URL=https://idp.example.com/.well-known/jwks.json
# OIDC_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
OIDC_ALGORITHMS=RS256
OIDC_LEEWAY_SECONDS=30
OIDC_SCOPE_CLAIMS=scope,scp,roles,groups,realm_access.roles
# OIDC_SCOPE_MAPPING={"admin":["imposbro:admin"],"admin:read":["imposbro:admin:read"],"admin:write":["imposbro:admin:write"],"admin:backup":["imposbro:admin:backup"],"admin:restore":["imposbro:admin:restore"],"admin:internal":["imposbro:admin:internal"],"search":["imposbro:search","imposbro:data"],"ingest":["imposbro:ingest","imposbro:data"],"data":["imposbro:data"]}
# OIDC tokens may also use collection-scoped claim values such as imposbro:search:products_*.
OIDC_SUBJECT_CLAIM=sub
ALLOW_INSECURE_OIDC_URLS=false

# Optional per-collection tenant policy. Use this alongside collection-scoped
# API/OIDC scopes when tenants or regions must be isolated server-side.
# AUTHZ_COLLECTION_POLICIES={"collections":{"orders_*":{"mode":"required","tenant_field":"tenant_id","tenant_claim":"tenant_id"}}}
AUTHZ_API_KEY_TENANT_BYPASS=true
AUTHZ_REQUIRE_COLLECTION_POLICY=false

# --- Data-plane API key (optional) ---
# If set, /ingest/*, /documents/*, and /search/* require X-API-Key or Authorization: Bearer.
# For local-only Docker Compose development, ALLOW_UNAUTHENTICATED_DATA=true
# lets smoke tests and manual API calls run without a key. Keep it false in shared/prod environments.
ALLOW_UNAUTHENTICATED_DATA=true
# DATA_API_KEY=your-secret-data-key
# Optional server-side key used by the Admin UI proxy; defaults to DATA_API_KEY when omitted.
# INTERNAL_QUERY_API_DATA_API_KEY=your-secret-data-key
INGEST_BATCH_MAX_DOCUMENTS=100

# --- Data-plane rate limiting (optional) ---
# Protects /search/*, document reads, /ingest/*, and document delete requests with fixed-window limits keyed by
# authenticated actor, or by client IP when running without auth. Use redis for
# multi-replica deployments; memory is only for single-process local/test runs.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SEARCH_REQUESTS=120
RATE_LIMIT_INGEST_REQUESTS=60
RATE_LIMIT_FAIL_CLOSED=false
RATE_LIMIT_REDIS_PREFIX=imposbro:rate_limit

# --- Admin audit log ---
# Records successful control-plane mutations to the internal state cluster.
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_DAYS=365
AUDIT_EXPORT_MAX_RESULTS=1000
AUDIT_LOG_MAX_RESULTS=100

# --- Local observability credentials ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only
